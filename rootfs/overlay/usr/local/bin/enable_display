#!/bin/bash
set -euo pipefail

export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-weston}"
export XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-weston}"
export WLR_DRM_DEVICES="${WLR_DRM_DEVICES:-/dev/dri/card0}"

sudo systemd-run --collect -E XDG_SESSION_TYPE=wayland --uid=1000 -p PAMName=login -p TTYPath=/dev/tty7 sleep 1d
systemctl --user start weston
export DISPLAY=:0
