[Unit]
Description=Android AVF shutdown runner
After=network.target virtiofs_internal.service
Wants=network.target virtiofs_internal.service
ConditionPathExists=/usr/lib/avf/shutdown_runner

[Service]
ExecStart=/usr/lib/avf/shutdown_runner --grpc-port-file /mnt/internal/debian_service_port
Restart=on-failure
RestartSec=1
User=root
Group=root

[Install]
WantedBy=multi-user.target
