[Unit]
Description=Android AVF storage balloon agent
After=network-online.target mnt-internal.mount
Wants=network-online.target mnt-internal.mount
ConditionPathExists=/usr/lib/avf/storage_balloon_agent

[Service]
ExecStart=/usr/lib/avf/storage_balloon_agent --grpc-port-file /mnt/internal/debian_service_port
Restart=on-failure
RestartSec=1
User=root
Group=root

[Install]
WantedBy=multi-user.target
