[Unit]
Description=Android AVF port forwarder
After=network.target virtiofs_internal.service
Wants=network.target virtiofs_internal.service
ConditionPathExists=/usr/lib/avf/forwarder_guest_launcher

[Service]
Environment=PATH=/usr/lib/avf:/usr/local/sbin:/usr/local/bin:/usr/bin
ExecStart=/usr/lib/avf/forwarder_guest_launcher --grpc-port-file /mnt/internal/debian_service_port
Restart=on-failure
RestartSec=1
User=root
Group=root

[Install]
WantedBy=multi-user.target
